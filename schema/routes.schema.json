{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mmalova.com/schema/routes.schema.json",
  "title": "Маршруты цифрового приложения",
  "type": "object",
  "required": [
    "routes"
  ],
  "additionalProperties": false,
  "properties": {
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "num",
          "title",
          "desc",
          "link",
          "status",
          "type"
        ],
        "additionalProperties": true,
        "properties": {
          "num": {
            "type": "string",
            "pattern": "^\\d{2}$"
          },
          "title": {
            "type": "string",
            "minLength": 2
          },
          "desc": {
            "type": "string",
            "minLength": 3
          },
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "link": {
            "type": "string",
            "pattern": "^/route/\\d{2}$"
          },
          "status": {
            "enum": [
              "done",
              "progress",
              "new"
            ]
          },
          "type": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
